---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const services = [
  {
    name: 'Troca de Tela',
    desc: 'Display original com cores vivas e toque preciso, com garantia.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="12" y2="15"/></svg>`,
    grad: 'linear-gradient(135deg, #006978 0%, #0a1628 100%)',
    img: '/images/services/tela.jpg',
  },
  {
    name: 'Bateria',
    desc: 'Substituição rápida por bateria original. Mais autonomia no dia a dia.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="16" height="10" rx="2"/><path d="M22 11v2"/><line x1="6" y1="12" x2="12" y2="12"/></svg>`,
    grad: 'linear-gradient(135deg, #004d5a 0%, #0d1f2d 100%)',
    img: '/images/services/bateria.jpg',
  },
  {
    name: 'Conector de Carga',
    desc: 'Reparo ou troca da porta de carregamento Lightning e USB-C.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M7 7v10M17 7v10M12 3v2m0 14v2M5 12h14"/></svg>`,
    grad: 'linear-gradient(135deg, #00695c 0%, #0a1a16 100%)',
    img: '/images/services/conector.jpg',
  },
  {
    name: 'Dano por Água',
    desc: 'Higienização profunda e recuperação de aparelhos molhados.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 2C12 2 5 9.5 5 14a7 7 0 0014 0c0-4.5-7-12-7-12z"/></svg>`,
    grad: 'linear-gradient(135deg, #1565c0 0%, #0a1020 100%)',
    img: '/images/services/agua.jpg',
  },
  {
    name: 'Câmera',
    desc: 'Restauramos a qualidade fotográfica com lentes e sensores originais.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
    grad: 'linear-gradient(135deg, #4a148c 0%, #0d0a1a 100%)',
    img: '/images/services/camera.jpg',
  },
  {
    name: 'Alto-falante',
    desc: 'Áudio cristalino restaurado com componentes de alta qualidade.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>`,
    grad: 'linear-gradient(135deg, #bf360c 0%, #1a0a00 100%)',
    img: '/images/services/audio.jpg',
  },
  {
    name: 'Face ID / Touch ID',
    desc: 'Recuperação de biometria com total segurança e peças originais Apple.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>`,
    grad: 'linear-gradient(135deg, #00695c 0%, #061410 100%)',
    img: '/images/services/faceid.jpg',
  },
  {
    name: 'Placa-mãe',
    desc: 'Microssoldagem e reparo de componentes eletrônicos com precisão.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M8 4v16M16 4v16M2 12h20M2 8h4M2 16h4M18 8h4M18 16h4"/></svg>`,
    grad: 'linear-gradient(135deg, #006978 0%, #030d12 100%)',
    img: '/images/services/placa-mae.jpg',
  },
  {
    name: 'Vidro Traseiro',
    desc: 'Troca do vidro traseiro com acabamento impecável e proteção renovada.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M9 6h6M9 18h6"/></svg>`,
    grad: 'linear-gradient(135deg, #37474f 0%, #0a0d10 100%)',
    img: '/images/services/vidro-traseiro.jpg',
  },
];
---

<BaseLayout
  title="Conecta Phone — Assistência Técnica Apple em Recife"
  description="Assistência técnica especializada em iPhone em Recife-PE. Troca de tela, bateria, conector e muito mais. Orçamento grátis e garantia no serviço."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1><span class="grad">Conserto Apple</span><br />em Recife</h1>
      <p class="hero-lead">
        Assistência Técnica Especializada Apple.<br />
        Diagnóstico gratuito, peças de qualidade e garantia em todos os reparos.
      </p>
      <div class="hero-actions">
        <a
          href="https://wa.me/5581991862060?text=Olá%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis"
          class="btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          Orçamento Grátis
        </a>
        <a href="/blog" class="btn-outline">Ver nosso blog</a>
      </div>
    </div>
  </section>

  <!-- Apple Products -->
  <section class="section products-section">
    <div class="container">
      <h2 class="section-title reveal">O que você precisa consertar?</h2>
      <p class="section-subtitle reveal">Clique no aparelho e fale com nosso técnico agora.</p>
      <div class="products-grid reveal-stagger">

        <a href="https://wa.me/5581991862060?text=Olá%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis" class="product-card product-card--photo" target="_blank" rel="noopener noreferrer">
          <div class="product-img product-img--photo">
            <img src="/images/iphone.png" alt="iPhone" width="600" height="600" loading="lazy" decoding="async" srcset="/images/iphone.png 600w" sizes="(max-width: 768px) 90vw, 300px" />
            <div class="product-photo-overlay"></div>
          </div>
          <div class="product-info">
            <span class="product-label">Conserte seu</span>
            <h3>iPhone</h3>
            <span class="product-cta">Falar no WhatsApp →</span>
          </div>
        </a>

        <a href="https://wa.me/5581991862060?text=Olá%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis" class="product-card product-card--photo" target="_blank" rel="noopener noreferrer">
          <div class="product-img product-img--photo">
            <img src="/images/apple-watch.png" alt="Apple Watch" width="600" height="600" loading="lazy" decoding="async" srcset="/images/apple-watch.png 600w" sizes="(max-width: 768px) 90vw, 300px" />
            <div class="product-photo-overlay"></div>
          </div>
          <div class="product-info">
            <span class="product-label">Conserte seu</span>
            <h3>Apple Watch</h3>
            <span class="product-cta">Falar no WhatsApp →</span>
          </div>
        </a>

        <a href="https://wa.me/5581991862060?text=Olá%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis" class="product-card product-card--photo" target="_blank" rel="noopener noreferrer">
          <div class="product-img product-img--photo">
            <img src="/images/ipad.png" alt="iPad" width="800" height="600" loading="lazy" decoding="async" srcset="/images/ipad.png 800w" sizes="(max-width: 768px) 90vw, 300px" />
            <div class="product-photo-overlay"></div>
          </div>
          <div class="product-info">
            <span class="product-label">Conserte seu</span>
            <h3>iPad</h3>
            <span class="product-cta">Falar no WhatsApp →</span>
          </div>
        </a>

        <a href="https://wa.me/5581991862060?text=Olá%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis" class="product-card product-card--photo" target="_blank" rel="noopener noreferrer">
          <div class="product-img product-img--photo">
            <img src="/images/macbook.png" alt="MacBook" width="800" height="600" loading="lazy" decoding="async" srcset="/images/macbook.png 800w" sizes="(max-width: 768px) 90vw, 300px" />
            <div class="product-photo-overlay"></div>
          </div>
          <div class="product-info">
            <span class="product-label">Conserte seu</span>
            <h3>MacBook</h3>
            <span class="product-cta">Falar no WhatsApp →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title reveal">Nossos Serviços</h2>
      <p class="section-subtitle reveal">iPhone, Apple Watch, iPad e MacBook — todos com agilidade e qualidade garantida.</p>
      <div class="services-grid reveal-stagger">
        {services.map(s => (
          <div class={`service-card${s.img ? ' service-card--photo' : ''}`}>
            {s.img ? (
              <img class="service-card-photo" src={s.img} alt={s.name} width="400" height="300" loading="lazy" decoding="async" srcset={`${s.img} 1200w`} sizes="(max-width: 480px) calc(50vw - 1rem), 220px" />
            ) : (
              <div class="service-card-bg" style={`background: ${s.grad};`}>
                <Fragment set:html={s.icon} />
              </div>
            )}
            <div class="service-card-overlay"></div>
            <div class="service-card-content">
              <h3>{s.name}</h3>
              <p>{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="section">
    <div class="container">
      <h2 class="section-title reveal">Por que escolher a <span class="grad">Conecta Phone</span>?</h2>
      <p class="section-subtitle reveal">Mais de 5 anos reparando dispositivos Apple em Recife com excelência.</p>
      <div class="why-grid reveal-stagger">
        <div class="why-card">
          <h3>Diagnóstico Gratuito</h3>
          <p>Avaliamos seu aparelho sem custo e só cobramos se você aprovar o orçamento.</p>
        </div>
        <div class="why-card">
          <h3>Peças Certificadas</h3>
          <p>Trabalhamos com peças originais Apple e OEM premium para garantir qualidade.</p>
        </div>
        <div class="why-card">
          <h3>Garantia de 90 dias</h3>
          <p>Todo reparo realizado na Conecta Phone tem garantia contra defeitos.</p>
        </div>
        <div class="why-card">
          <h3>Atendimento Rápido</h3>
          <p>A maioria dos reparos é concluída no mesmo dia, em 1 a 2 horas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section reviews-section">
    <div class="container">
      <div class="reviews-header reveal">
        <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div>
          <h2 class="section-title" style="margin-bottom:0.25rem;">O que nossos clientes dizem</h2>
          <div class="reviews-rating-line">
            <span class="stars-display">★★★★★</span>
            <span class="reviews-score">4,9</span>
            <span class="reviews-count">· mais de 750 avaliações no Google</span>
          </div>
        </div>
      </div>

      <div class="reviews-track reveal-stagger">

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-text">"Excelente serviço e atendimento. Foi bastante rápido e eficiente! Muito bem atendida pelo Marcos, excelente profissional."</p>
          <div class="review-author">
            <span class="review-avatar">W</span>
            <div>
              <strong>Wictor Amorim</strong>
              <span>Há 16 semanas</span>
            </div>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-text">"Recomendo demais! Sempre que preciso, eles resolvem tudo super rápido e sempre entregam no mesmo dia. O atendimento é excelente, a equipe é super prestativa e explica tudo direitinho. Já virei cliente fiel! 💙"</p>
          <div class="review-author">
            <span class="review-avatar">M</span>
            <div>
              <strong>Madu</strong>
              <span>Há 2 semanas</span>
            </div>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-text">"Fiz um conserto de placa do meu iPhone e fui muito bem atendida. Tinha um prazo mais curto e eles conseguiram me atender no dia que precisava. Deu tudo certo! Super recomendo."</p>
          <div class="review-author">
            <span class="review-avatar">L</span>
            <div>
              <strong>Laura Lakitini</strong>
              <span>Há 15 semanas</span>
            </div>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-text">"Levei meu iPhone 12 para troca de bateria e da tampa traseira. Fui muito bem atendida pelo WhatsApp e o retorno foi rápido. No presencial o espaço é agradável e me entregaram antes do prazo. Nota 10 💗"</p>
          <div class="review-author">
            <span class="review-avatar">A</span>
            <div>
              <strong>Alyce</strong>
              <span>Há 4 semanas</span>
            </div>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-text">"Precisei consertar a traseira e a lente do meu iPhone 14 Pro Max. Vieram buscar na minha residência e devolveram tudo pronto no mesmo dia. O atendimento foi muito atencioso e me passou muita confiança."</p>
          <div class="review-author">
            <span class="review-avatar">T</span>
            <div>
              <strong>Thamyres Santos</strong>
              <span>Há 7 semanas</span>
            </div>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-text">"Experiência maravilhosa desde o primeiro contato. A opção de delivery é segura, o motoqueiro é educado. O serviço é impecável. Voltarei a fazer serviços com eles."</p>
          <div class="review-author">
            <span class="review-avatar">J</span>
            <div>
              <strong>Juliana Luna</strong>
              <span>Há 2 semanas</span>
            </div>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-text">"Troquei a cabine traseira do 12 e o resultado superou as expectativas. Ficou muito bom mesmo, capricho total. Atendimento maravilhoso, atencioso e profissional. Nota 10!"</p>
          <div class="review-author">
            <span class="review-avatar">R</span>
            <div>
              <strong>Ralyssa Cirne</strong>
              <span>Há 6 semanas</span>
            </div>
          </div>
        </div>

      </div>

      <div style="text-align:center; margin-top:2.5rem;" class="reveal">
        <a href="https://share.google/rktOQ5pgkn5dEPEh1" class="btn-outline" target="_blank" rel="noopener noreferrer">
          Ver todas as avaliações no Google
        </a>
      </div>
    </div>
  </section>

  <!-- Latest posts -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title reveal">Do nosso Blog</h2>
      <p class="section-subtitle reveal">Dicas, tutoriais e informações sobre cuidados com seus dispositivos Apple.</p>
      <div class="posts-grid reveal-stagger">
        {latestPosts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            author={post.data.author}
            tags={post.data.tags}
          />
        ))}
      </div>
      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/blog" class="btn">Ver todos os posts</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Seu <span class="grad">Apple</span> com problema? Fale agora!</h2>
      <p>iPhone, Apple Watch, iPad ou MacBook — atendemos tudo em Recife ou pelo WhatsApp.</p>
      <a
        href="https://wa.me/5581991862060?text=Olá%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis"
        class="btn-white"
        target="_blank"
        rel="noopener noreferrer"
      >
        Chamar no WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Products ── */
  .products-section {
    background: #fff;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  @media (min-width: 900px) {
    .products-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .product-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    background: #121314;
    border-radius: 1.25rem;
    overflow: hidden;
    padding: 2rem 1.25rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.06);
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), box-shadow 0.35s ease;
    gap: 1.25rem;
  }

  .product-card:hover {
    transform: translateY(-7px);
    box-shadow: 0 20px 48px rgba(31,195,255,0.28);
    text-decoration: none;
  }

  .product-img {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    flex: 1;
  }

  .product-img svg {
    color: var(--teal);
    height: 120px;
    width: auto;
    filter: drop-shadow(0 0 18px rgba(0,188,212,0.4));
    transition: filter 0.3s, transform 0.3s;
  }

  .product-card:hover .product-img svg {
    filter: drop-shadow(0 0 28px rgba(0,188,212,0.7));
    transform: scale(1.06);
  }

  .product-info {
    width: 100%;
    text-align: center;
  }

  .product-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 500;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.2rem;
  }

  .product-info h3 {
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, #1FC3FF 0%, #80e8ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .product-cta {
    display: inline-block;
    background: #25D366;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .product-card--photo {
    padding: 0;
    overflow: hidden;
    position: relative;
  }

  .product-img--photo {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .product-img--photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.4s ease;
  }

  .product-card--photo:hover .product-img--photo img {
    transform: scale(1.06);
  }

  .product-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.80) 35%, rgba(0,0,0,0.15) 100%);
  }

  .product-card--photo .product-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem;
  }

  /* ── Why ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .why-card {
    padding: 1.75rem 1.5rem 1.5rem;
    border-radius: 1rem;
    border: 1px solid #D9E6EC;
    background: #fff;
    position: relative;
