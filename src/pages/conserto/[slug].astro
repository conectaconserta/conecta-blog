---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('conserto');
  return pages.map(page => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await page.render();
const { title, description, device, generation, models, services, heroText } = page.data;

const whatsappUrl =
  'https://wa.me/5581991862060?text=Ol%C3%A1%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis';

// Fotos reais de fundo (background-image) para iPhones com imagem própria
const heroPhotos: Record<string, string> = {
  'iphone-7':  '/images/conserto/iphone-7.jpeg',
  'iphone-8':  '/images/conserto/iphone-8.jpeg',
  'iphone-x':  '/images/conserto/iphone-x.png',
  'iphone-se': '/images/conserto/iphone-se.jpg',
  'iphone-11': '/images/conserto/iphone-11.png',
  'iphone-12': '/images/conserto/iphone-12.jpeg',
  'iphone-13': '/images/conserto/iphone-13.jpg',
  'iphone-14': '/images/conserto/iphone-14.png',
  'iphone-15': '/images/conserto/iphone-15.png',
  'iphone-16': '/images/conserto/iphone-16.jpg',
  'iphone-17': '/images/conserto/iphone-17.png',
};
const heroPhoto = heroPhotos[page.slug] ?? null;

// Imagem PNG do dispositivo (two-column) para páginas sem foto própria
const deviceImages: Record<string, string> = {
  'iPhone':      '/images/iphone.png',
  'iPad':        '/images/ipad.png',
  'MacBook':     '/images/macbook.png',
  'Apple Watch': '/images/apple-watch.png',
};
const heroImage = deviceImages[device] ?? '/images/iphone.png';

// Mapeamento de serviço → foto (usa as fotos da homepage)
const serviceImages: Record<string, string> = {
  // Nomes padronizados iPhones
  'Troca de Tela':              '/images/services/tela.jpg',
  'Vidro Traseiro':             '/images/services/vidro-traseiro.jpg',
  'Troca de Bateria':           '/images/services/bateria.jpg',
  'Conector de Carga':          '/images/services/conector.jpg',
  'Câmera Traseira/Frontal':    '/images/services/camera.jpg',
  'Face ID':                    '/images/services/faceid.jpg',
  'Touch ID':                   '/images/services/faceid.jpg',
  'Botões':                     '/images/conserto/botao-iphone.jpg',
  'Alto-falante/Microfone':     '/images/services/audio.jpg',
  'Dano por Líquido':           '/images/services/agua.jpg',
  // Apple Watch
  'Tela e vidro':               '/images/services/aw-tela.jpg',
  'Bateria':                    '/images/services/aw-bateria.jpg',
  'Dano por líquido':           '/images/services/aw-dano-liquido.jpg',
  // iPads
  'Câmera traseira':            '/images/services/camera.jpg',
  'Câmera frontal':             '/images/services/faceid.jpg',
  'Botão Home / Touch ID':      '/images/services/faceid.jpg',
  'Touch ID lateral':           '/images/services/faceid.jpg',
  'Conector USB-C':             '/images/services/conector.jpg',
  // MacBook
  'Troca de tela':              '/images/services/tela.jpg',
  'Troca de tela Liquid Retina XDR': '/images/services/tela.jpg',
  'Troca de bateria':           '/images/services/bateria.jpg',
  'Teclado':                    '/images/services/placa-mae.jpg',
  'Trackpad':                   '/images/services/placa-mae.jpg',
  'Conector MagSafe / USB-C':   '/images/services/conector.jpg',
  'Conector MagSafe / Thunderbolt': '/images/services/conector.jpg',
  'Placa-mãe':                  '/images/services/placa-mae.jpg',
  'Upgrade de SSD':             '/images/services/placa-mae.jpg',
  // Apple Watch
  'Troca de tela':              '/images/services/tela.jpg',
  'Coroa digital':              '/images/conserto/botao-iphone.jpg',
  'Botão lateral':              '/images/conserto/botao-iphone.jpg',
  'Carcaça / chassi':           '/images/services/vidro-traseiro.jpg',
  'Sensor de saúde':            '/images/services/faceid.jpg',
};

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Conserto de ${generation} em Recife`,
  description,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Conecta Phone',
    telephone: '+55-81-99186-2060',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Recife',
      addressRegion: 'PE',
      addressCountry: 'BR',
    },
  },
  areaServed: { '@type': 'City', name: 'Recife' },
});
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={schema} />

  <!-- Hero — background com overlay -->
  <header
    class="conserto-hero"
    style={`background-image: url('${heroPhoto ?? heroImage}')`}
  >
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <nav class="breadcrumb" aria-label="Navegação estrutural">
        <a href="/">Início</a><span>›</span>
        <a href="/#servicos">Serviços</a><span>›</span>
        <span>{generation}</span>
      </nav>
      <p class="device-label">{device}</p>
      <h1>Conserto de {generation} em Recife</h1>
      <p class="hero-sub">{heroText}</p>
      <div class="hero-actions">
        <a href={whatsappUrl} class="btn-hero" target="_blank" rel="noopener noreferrer">
          Orçamento grátis via WhatsApp
        </a>
        <span class="hero-badge">Diagnóstico gratuito · Garantia 90 dias</span>
      </div>
    </div>
  </header>

  <!-- Services Grid -->
  <section class="section services-section">
    <div class="container">
      <h2 class="section-title reveal">Serviços disponíveis para {generation}</h2>
      <p class="section-sub reveal">Atendimento no mesmo dia para a maioria dos reparos. Peças certificadas com garantia.</p>
      <div class="services-grid reveal-stagger">
        {services.map(service => {
          const img = serviceImages[service];
          return (
            <div class="service-card">
              {img ? (
                <img class="service-card-photo" src={img} alt={service} width="300" height="200" loading="lazy" decoding="async" srcset={`${img} 1200w`} sizes="(max-width: 480px) calc(50vw - 1rem), 180px" />
              ) : (
                <div class="service-card-fallback"></div>
              )}
              <div class="service-card-overlay"></div>
              <div class="service-card-content">
                <span class="service-name">{service}</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Models -->
  <section class="section models-section">
    <div class="container">
      <h2 class="section-title reveal">Modelos atendidos</h2>
      <div class="models-list reveal-stagger">
        {models.map(model => (
          <span class="model-chip">{model}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SEO Content -->
  <section class="section content-section">
    <div class="container">
      <div class="article-body reveal">
        <Content />
      </div>
    </div>
  </section>

  <!-- Differentials -->
  <section class="section diferenciais-section">
    <div class="container">
      <h2 class="section-title reveal">Por que escolher a Conecta Phone?</h2>
      <div class="diferenciais-grid reveal-stagger">
        <div class="diferencial-card">
          <strong>Diagnóstico gratuito</strong>
          <p>Avaliamos o aparelho sem custo antes de qualquer intervenção.</p>
        </div>
        <div class="diferencial-card">
          <strong>Peças certificadas</strong>
          <p>Componentes de qualidade compatíveis com os padrões originais.</p>
        </div>
        <div class="diferencial-card">
          <strong>Garantia de 90 dias</strong>
          <p>Todo reparo tem cobertura contra defeitos no componente substituído.</p>
        </div>
        <div class="diferencial-card">
          <strong>Coleta e entrega</strong>
          <p>Buscamos e devolvemos seu aparelho em Recife sem custo adicional.</p>
        </div>
        <div class="diferencial-card">
          <strong>Parcelamento 6x sem juros</strong>
          <p>Pague no cartão em até 6 parcelas sem acréscimo.</p>
        </div>
        <div class="diferencial-card">
          <strong>+750 avaliações no Google</strong>
          <p>Referência em assistência Apple em Recife há anos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Seu {generation} precisa de reparo?</h2>
      <p>Diagnóstico gratuito, reparo no mesmo dia e garantia de 90 dias. Fale agora com um técnico.</p>
      <a href={whatsappUrl} class="btn-white" target="_blank" rel="noopener noreferrer">
        Chamar no WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .conserto-hero {
    position: relative;
    background-size: cover;
    background-position: center right;
    background-repeat: no-repeat;
    background-color: var(--navy);
    color: #fff;
    min-height: 520px;
    display: flex;
    align-items: center;
    padding: 5rem 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(10, 20, 40, 0.97) 0%,
      rgba(10, 20, 40, 0.90) 35%,
      rgba(10, 20, 40, 0.60) 60%,
      rgba(10, 20, 40, 0.15) 100%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 600px;
  }

  .conserto-hero .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 1.5rem;
  }

  .conserto-hero .breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
  .conserto-hero .breadcrumb a:hover { color: var(--cyan); }

  .device-label {
    display: inline-block;
    background: var(--cyan);
    color: var(--navy);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  .conserto-hero h1 {
    color: #fff;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-hero {
    display: inline-block;
    background: #25D366;
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.85rem 1.75rem;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(37,211,102,0.35);
  }

  .btn-hero:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(37,211,102,0.45);
  }

  .hero-badge { font-size: 0.8rem; color: rgba(255,255,255,0.65); }

  /* ── Services ── */
  .services-section { background: var(--gray-50); }

  .section-sub {
    color: var(--gray-500);
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.6rem;
    margin-top: 1.5rem;
  }

  .service-card {
    position: relative;
    border-radius: 0.6rem;
    overflow: hidden;
    height: 72px;
    cursor: default;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .service-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }

  .service-card-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .service-card:hover .service-card-photo { transform: scale(1.06); }

  .service-card-fallback {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--navy) 0%, #1a4a6e 100%);
  }

  .service-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(10,20,40,0.80) 0%, rgba(10,20,40,0.45) 100%);
  }

  .service-card-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    padding: 0 1rem;
  }

  .service-name {
    font-size: 0.8rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }

  /* ── Models ── */
  .models-section { background: #fff; }

  .models-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .model-chip {
    background: var(--cyan-light);
    color: var(--navy);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(31,195,255,0.3);
  }

  /* ── Content — mesmo estilo do blog ── */
  .content-section { background: var(--gray-50); }

  .conserto-content {
    max-width: 720px;
    margin: 3rem auto 4rem;
    padding: 0 1.5rem;
  }

  .conserto-content h2 {
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    font-size: 1.45rem;
    font-weight: 800;
    color: var(--navy);
    padding-top: 3rem;
    margin: 0 0 1.25rem;
    line-height: 1.25;
    letter-spacing: -0.02em;
    border-left: 3px solid var(--cyan);
    padding-left: 0.85rem;
  }

  .conserto-content h2:first-child {
    padding-top: 0;
  }

  .conserto-content h3 {
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
    padding-top: 2rem;
    margin: 0 0 0.85rem;
    letter-spacing: -0.01em;
  }

  .conserto-content p {
    margin-bottom: 1.35rem;
    line-height: 1.85;
    color: #3F444B;
  }

  .conserto-content ul,
  .conserto-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.35rem;
  }

  .conserto-content li {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }

  .conserto-content strong {
    color: var(--navy);
    font-weight: 700;
  }

  .conserto-content blockquote {
    border-left: 3px solid var(--cyan);
    padding: 1.1rem 1.5rem;
    background: linear-gradient(to right, rgba(31,195,255,0.07), transparent);
    border-radius: 0 0.5rem 0.5rem 0;
    margin: 2rem 0;
    color: var(--navy);
    font-weight: 500;
  }

  .conserto-content a {
    color: var(--cyan-dark);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  /* ── Differentials ── */
  .diferenciais-section { background: #fff; }

  .diferenciais-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .diferencial-card {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .diferencial-card strong { display: block; color: var(--navy); font-size: 0.95rem; margin-bottom: 0.4rem; }
  .diferencial-card p { font-size: 0.85rem; color: var(--gray-500); line-height: 1.6; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .conserto-hero {
      background-position: center;
      min-height: 420px;
    }
    .hero-overlay {
      background: linear-gradient(
        to bottom,
        rgba(10, 20, 40, 0.88) 0%,
        rgba(10, 20, 40, 0.82) 100%
      );
    }
    .hero-inner { max-width: 100%; }
    .services-grid { grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
    .hero-actions { flex-direction: column; align-items: flex-start; }
    .diferenciais-grid { grid-template-columns: 1fr; }
  }
</style>
