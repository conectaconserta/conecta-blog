---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('conserto');
  return pages.map(page => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await page.render();
const { title, description, device, generation, models, services, heroText } = page.data;

const whatsappUrl =
  'https://wa.me/5581991862060?text=Ol%C3%A1%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis';

// Imagem do dispositivo no hero
const deviceImages: Record<string, string> = {
  'iPhone':      '/images/iphone.png',
  'iPad':        '/images/ipad.png',
  'MacBook':     '/images/macbook.png',
  'Apple Watch': '/images/apple-watch.png',
};
const heroImage = deviceImages[device] ?? '/images/iphone.png';

// Mapeamento de serviço → foto (usa as fotos da homepage)
const serviceImages: Record<string, string> = {
  'Troca de tela':              '/images/services/tela.jpg',
  'Troca de tela OLED':         '/images/services/tela.jpg',
  'Troca de tela Liquid Retina XDR': '/images/services/tela.jpg',
  'Vidro traseiro':             '/images/services/vidro-traseiro.jpg',
  'Troca de bateria':           '/images/services/bateria.jpg',
  'Conector de carga':          '/images/services/conector.jpg',
  'Conector USB-C':             '/images/services/conector.jpg',
  'Conector MagSafe / USB-C':   '/images/services/conector.jpg',
  'Conector MagSafe / Thunderbolt': '/images/services/conector.jpg',
  'Câmera traseira':            '/images/services/camera.jpg',
  'Câmera traseira 48MP':       '/images/services/camera.jpg',
  'Câmera frontal':             '/images/services/faceid.jpg',
  'Câmera frontal / Face ID':   '/images/services/faceid.jpg',
  'Alto-falante':               '/images/services/audio.jpg',
  'Touch ID':                   '/images/services/faceid.jpg',
  'Touch ID lateral':           '/images/services/faceid.jpg',
  'Face ID / Touch ID':         '/images/services/faceid.jpg',
  'Botão Camera Control':       '/images/services/tela.jpg',
  'Microfone':                  '/images/services/audio.jpg',
  'Dano por líquido':           '/images/services/agua.jpg',
  'Placa-mãe':                  '/images/services/placa-mae.jpg',
  'Teclado':                    '/images/services/placa-mae.jpg',
  'Trackpad':                   '/images/services/placa-mae.jpg',
  'Upgrade de SSD':             '/images/services/placa-mae.jpg',
  'Coroa digital':              '/images/services/tela.jpg',
  'Botão lateral':              '/images/services/conector.jpg',
  'Carcaça / chassi':           '/images/services/vidro-traseiro.jpg',
  'Sensor de saúde':            '/images/services/faceid.jpg',
  'Botão Home / Touch ID':      '/images/services/faceid.jpg',
};

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Conserto de ${generation} em Recife`,
  description,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Conecta Phone',
    telephone: '+55-81-99186-2060',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Recife',
      addressRegion: 'PE',
      addressCountry: 'BR',
    },
  },
  areaServed: { '@type': 'City', name: 'Recife' },
});
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={schema} />

  <!-- Hero -->
  <header class="conserto-hero" style={`--hero-img: url('${heroImage}')`}>
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <nav class="breadcrumb" aria-label="Navegação estrutural">
        <a href="/">Início</a><span>›</span>
        <a href="/#servicos">Serviços</a><span>›</span>
        <span>{generation}</span>
      </nav>
      <p class="device-label">{device}</p>
      <h1>Conserto de {generation} em Recife</h1>
      <p class="hero-sub">{heroText}</p>
      <div class="hero-actions">
        <a href={whatsappUrl} class="btn-hero" target="_blank" rel="noopener noreferrer">
          Orçamento grátis via WhatsApp
        </a>
        <span class="hero-badge">Diagnóstico gratuito · Garantia 90 dias</span>
      </div>
    </div>
  </header>

  <!-- Services Grid -->
  <section class="section services-section">
    <div class="container">
      <h2 class="section-title reveal">Serviços disponíveis para {generation}</h2>
      <p class="section-sub reveal">Atendimento no mesmo dia para a maioria dos reparos. Peças certificadas com garantia.</p>
      <div class="services-grid reveal-stagger">
        {services.map(service => {
          const img = serviceImages[service];
          return (
            <div class="service-card">
              {img ? (
                <img class="service-card-photo" src={img} alt={service} loading="lazy" />
              ) : (
                <div class="service-card-fallback"></div>
              )}
              <div class="service-card-overlay"></div>
              <div class="service-card-content">
                <span class="service-name">{service}</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Models -->
  <section class="section models-section">
    <div class="container">
      <h2 class="section-title reveal">Modelos atendidos</h2>
      <div class="models-list reveal-stagger">
        {models.map(model => (
          <span class="model-chip">{model}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SEO Content -->
  <section class="section content-section">
    <div class="container">
      <div class="conserto-content reveal">
        <Content />
      </div>
    </div>
  </section>

  <!-- Differentials -->
  <section class="section diferenciais-section">
    <div class="container">
      <h2 class="section-title reveal">Por que escolher a Conecta Phone?</h2>
      <div class="diferenciais-grid reveal-stagger">
        <div class="diferencial-card">
          <strong>Diagnóstico gratuito</strong>
          <p>Avaliamos o aparelho sem custo antes de qualquer intervenção.</p>
        </div>
        <div class="diferencial-card">
          <strong>Peças certificadas</strong>
          <p>Componentes de qualidade compatíveis com os padrões originais.</p>
        </div>
        <div class="diferencial-card">
          <strong>Garantia de 90 dias</strong>
          <p>Todo reparo tem cobertura contra defeitos no componente substituído.</p>
        </div>
        <div class="diferencial-card">
          <strong>Coleta e entrega</strong>
          <p>Buscamos e devolvemos seu aparelho em Recife sem custo adicional.</p>
        </div>
        <div class="diferencial-card">
          <strong>Parcelamento 6x sem juros</strong>
          <p>Pague no cartão em até 6 parcelas sem acréscimo.</p>
        </div>
        <div class="diferencial-card">
          <strong>+750 avaliações no Google</strong>
          <p>Referência em assistência Apple em Recife há anos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Seu {generation} precisa de reparo?</h2>
      <p>Diagnóstico gratuito, reparo no mesmo dia e garantia de 90 dias. Fale agora com um técnico.</p>
      <a href={whatsappUrl} class="btn-white" target="_blank" rel="noopener noreferrer">
        Chamar no WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .conserto-hero {
    position: relative;
    background-image: var(--hero-img);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: right center;
    background-color: var(--navy);
    color: #fff;
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(20, 51, 79, 0.98) 0%,
      rgba(20, 51, 79, 0.90) 45%,
      rgba(20, 51, 79, 0.45) 70%,
      rgba(20, 51, 79, 0.15) 100%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 620px;
  }

  .conserto-hero .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 1.5rem;
  }

  .conserto-hero .breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
  .conserto-hero .breadcrumb a:hover { color: var(--cyan); }

  .device-label {
    display: inline-block;
    background: var(--cyan);
    color: var(--navy);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  .conserto-hero h1 {
    color: #fff;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-hero {
    display: inline-block;
    background: #25D366;
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.85rem 1.75rem;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(37,211,102,0.35);
  }

  .btn-hero:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(37,211,102,0.45);
  }

  .hero-badge { font-size: 0.8rem; color: rgba(255,255,255,0.65); }

  /* ── Services ── */
  .services-section { background: var(--gray-50); }

  .section-sub {
    color: var(--gray-500);
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .service-card {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 4/3;
    cursor: default;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .service-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }

  .service-card-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .service-card:hover .service-card-photo { transform: scale(1.06); }

  .service-card-fallback {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--navy) 0%, #1a4a6e 100%);
  }

  .service-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,20,40,0.85) 0%, rgba(10,20,40,0.2) 60%, transparent 100%);
  }

  .service-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.875rem 1rem;
  }

  .service-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  /* ── Models ── */
  .models-section { background: #fff; }

  .models-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .model-chip {
    background: var(--cyan-light);
    color: var(--navy);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(31,195,255,0.3);
  }

  /* ── Content ── */
  .content-section { background: var(--gray-50); }

  .conserto-content {
    max-width: 780px;
    line-height: 1.8;
    color: var(--gray-700);
  }

  .conserto-content h2 { font-size: 1.35rem; color: var(--navy); margin: 2rem 0 0.75rem; }
  .conserto-content h3 { font-size: 1.1rem; color: var(--navy); margin: 1.5rem 0 0.5rem; }
  .conserto-content p { margin-bottom: 1rem; }
  .conserto-content ul, .conserto-content ol { margin: 0.75rem 0 1rem 1.5rem; }
  .conserto-content li { margin-bottom: 0.4rem; }
  .conserto-content strong { color: var(--navy); }

  /* ── Differentials ── */
  .diferenciais-section { background: #fff; }

  .diferenciais-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .diferencial-card {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .diferencial-card strong { display: block; color: var(--navy); font-size: 0.95rem; margin-bottom: 0.4rem; }
  .diferencial-card p { font-size: 0.85rem; color: var(--gray-500); line-height: 1.6; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .conserto-hero {
      background-position: center top;
      background-size: cover;
    }
    .hero-overlay {
      background: linear-gradient(
        to bottom,
        rgba(20,51,79,0.92) 0%,
        rgba(20,51,79,0.85) 100%
      );
    }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-actions { flex-direction: column; align-items: flex-start; }
    .diferenciais-grid { grid-template-columns: 1fr; }
  }
</style>
