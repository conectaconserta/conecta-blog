---
interface Props {
  title: string;
  description: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  author?: string;
  tags?: string[];
}

const {
  title,
  description,
  type = 'website',
  publishDate,
  author = 'Equipe Conecta Phone',
  tags = [],
} = Astro.props;

const siteUrl = 'https://conecta-blog.vercel.app';
const fullTitle = title === 'Conecta Phone' ? title : `${title} | Conecta Phone`;
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate?.toISOString(),
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Conecta Phone',
    url: siteUrl,
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Av. Antônio de Góes, 14',
      addressLocality: 'Recife',
      addressRegion: 'PE',
      postalCode: '51110-150',
      addressCountry: 'BR',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
};

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Conecta Phone',
  description: 'Assistência técnica especializada em iPhones e smartphones em Recife-PE.',
  url: siteUrl,
  telephone: '+55-81-99186-2060',
  email: 'contato@conectaphone.com.br',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Av. Antônio de Góes, 14',
    addressLocality: 'Recife',
    addressRegion: 'PE',
    postalCode: '51110-150',
    addressCountry: 'BR',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '09:00',
      closes: '14:00',
    },
  ],
};

const jsonLd = type === 'article' ? articleSchema : businessSchema;
---

<title>{fullTitle}</title>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonicalURL} />
{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="Conecta Phone" />
<meta property="og:locale" content="pt_BR" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
