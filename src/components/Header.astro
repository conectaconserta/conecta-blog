---
const currentPath = Astro.url.pathname;

const menus = [
  {
    id: 'iphone',
    label: 'iPhone',
    items: [
      { href: '/conserto/iphone-17/', label: 'iPhone 17' },
      { href: '/conserto/iphone-16/', label: 'iPhone 16' },
      { href: '/conserto/iphone-15/', label: 'iPhone 15' },
      { href: '/conserto/iphone-14/', label: 'iPhone 14' },
      { href: '/conserto/iphone-13/', label: 'iPhone 13' },
      { href: '/conserto/iphone-12/', label: 'iPhone 12' },
      { href: '/conserto/iphone-11/', label: 'iPhone 11' },
      { href: '/conserto/iphone-se/', label: 'iPhone SE' },
      { href: '/conserto/iphone-x/',  label: 'iPhone X / XS / XR' },
      { href: '/conserto/iphone-8/',  label: 'iPhone 8' },
      { href: '/conserto/iphone-7/',  label: 'iPhone 7' },
    ],
  },
  {
    id: 'apple-watch',
    label: 'Apple Watch',
    items: [
      { href: '/conserto/apple-watch-series/', label: 'Apple Watch Series' },
      { href: '/conserto/apple-watch-se/',     label: 'Apple Watch SE' },
      { href: '/conserto/apple-watch-nike/',   label: 'Apple Watch Nike' },
    ],
  },
  {
    id: 'ipad',
    label: 'iPad',
    items: [
      { href: '/conserto/ipad-pro/',  label: 'iPad Pro' },
      { href: '/conserto/ipad-air/',  label: 'iPad Air' },
      { href: '/conserto/ipad-mini/', label: 'iPad Mini' },
      { href: '/conserto/ipad/',      label: 'iPad' },
    ],
  },
  {
    id: 'macbook',
    label: 'MacBook',
    items: [
      { href: '/conserto/macbook-pro/', label: 'MacBook Pro' },
      { href: '/conserto/macbook-air/', label: 'MacBook Air' },
    ],
  },
];
---

<header>
  <div class="container">
    <a href="/" class="logo">
      <img src="/images/logo-header.png" alt="Conecta Phone" class="logo-img" width="160" height="40" srcset="/images/logo-header.png 1x" />
    </a>

    <nav id="main-nav">
      {menus.map(menu => {
        const isActive = menu.items.some(i => currentPath === i.href);
        return (
          <div class="nav-dropdown" data-menu={menu.id}>
            <button
              class:list={['nav-dropdown-trigger', { active: isActive }]}
              aria-haspopup="true"
              aria-expanded="false"
            >
              {menu.label}
              <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="dropdown-panel" role="menu">
              {menu.items.map(item => (
                <a
                  href={item.href}
                  class:list={['dropdown-item', { 'dropdown-item--active': currentPath === item.href }]}
                  role="menuitem"
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        );
      })}

      <a href="/blog"    class:list={[{ active: currentPath.startsWith('/blog') }]}>Blog</a>
      <a href="/contato" class:list={[{ active: currentPath === '/contato' }]}>Contato</a>
    </nav>

    <a
      href="https://wa.me/5581991862060?text=Ol%C3%A1%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis"
      class="btn-header-cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      WhatsApp
    </a>

    <button class="hamburger" id="hamburger-btn" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script is:inline>
  (function () {
    // Fecha todos os dropdowns abertos
    function closeAll(except) {
      document.querySelectorAll('.nav-dropdown').forEach(function (d) {
        if (d === except) return;
        var btn = d.querySelector('.nav-dropdown-trigger');
        var panel = d.querySelector('.dropdown-panel');
        if (btn) btn.setAttribute('aria-expanded', 'false');
        if (panel) panel.classList.remove('open');
      });
    }

    // Inicializa cada dropdown
    document.querySelectorAll('.nav-dropdown').forEach(function (dropdown) {
      var btn = dropdown.querySelector('.nav-dropdown-trigger');
      var panel = dropdown.querySelector('.dropdown-panel');
      if (!btn || !panel) return;

      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = btn.getAttribute('aria-expanded') === 'true';
        closeAll(open ? null : dropdown);
        btn.setAttribute('aria-expanded', String(!open));
        panel.classList.toggle('open', !open);
      });
    });

    // Fecha ao clicar fora
    document.addEventListener('click', function () { closeAll(null); });

    // Mobile hamburger
    var hamburger = document.getElementById('hamburger-btn');
    var nav = document.getElementById('main-nav');
    if (hamburger && nav) {
      hamburger.addEventListener('click', function () {
        var open = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!open));
        hamburger.classList.toggle('open', !open);
        nav.classList.toggle('mobile-open', !open);
      });
    }
  })();
</script>

<style>
  header {
    background: #fff;
    padding: 1rem 0;
    border-bottom: 1px solid #E8EFF4;
    box-shadow: 0 1px 12px rgba(20,51,79,0.07);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .logo { display: flex; align-items: center; text-decoration: none; flex-shrink: 0; }
  .logo-img { height: 40px; width: auto; object-fit: contain; }

  /* ── Nav ── */
  nav {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    flex: 1;
    justify-content: center;
  }

  nav > a {
    color: #14334F;
    padding: 0.45rem 0.75rem;
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.88rem;
    text-decoration: none;
    position: relative;
    transition: color 0.2s;
    white-space: nowrap;
  }

  nav > a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    background: #1FC3FF;
    border-radius: 2px;
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  nav > a:hover { color: #0099CC; }
  nav > a:hover::after { transform: scaleX(1); }
  nav > a.active { color: #0099CC; font-weight: 600; }
  nav > a.active::after { transform: scaleX(1); }

  /* ── Dropdown ── */
  .nav-dropdown { position: relative; }

  .nav-dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    color: #14334F;
    padding: 0.45rem 0.75rem;
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.88rem;
    transition: color 0.2s;
    position: relative;
    white-space: nowrap;
  }

  .nav-dropdown-trigger::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    background: #1FC3FF;
    border-radius: 2px;
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .nav-dropdown-trigger:hover { color: #0099CC; }
  .nav-dropdown-trigger:hover::after { transform: scaleX(1); }
  .nav-dropdown-trigger.active { color: #0099CC; font-weight: 600; }
  .nav-dropdown-trigger.active::after { transform: scaleX(1); }

  .chevron { transition: transform 0.2s ease; flex-shrink: 0; }
  .nav-dropdown-trigger[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  /* Dropdown panel — coluna simples */
  .dropdown-panel {
    display: none;
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    border: 1px solid #E8EFF4;
    border-radius: 0.875rem;
    box-shadow: 0 12px 40px rgba(20,51,79,0.14);
    padding: 0.5rem;
    min-width: 200px;
    z-index: 2000;
    flex-direction: column;
  }

  .dropdown-panel.open { display: flex; }

  /* Hover também abre no desktop */
  @media (hover: hover) {
    .nav-dropdown:hover .dropdown-panel { display: flex; }
    .nav-dropdown:hover .nav-dropdown-trigger .chevron { transform: rotate(180deg); }
  }

  .dropdown-item {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #14334F;
    text-decoration: none;
    border-radius: 0.5rem;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .dropdown-item:hover { background: #F0F9FF; color: #0099CC; }
  .dropdown-item--active { background: #E0F7FE; color: #0099CC; font-weight: 600; }

  /* ── WhatsApp CTA ── */
  .btn-header-cta {
    background: #25D366;
    color: #fff;
    padding: 0.5rem 1.1rem;
    border-radius: 100px;
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .btn-header-cta:hover {
    background: #1fad54;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(37,211,102,0.38);
  }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    flex-shrink: 0;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #14334F;
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .hamburger { display: flex; }
    .btn-header-cta { display: none; }

    nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #fff;
      border-top: 1px solid #E8EFF4;
      box-shadow: 0 8px 24px rgba(20,51,79,0.12);
      flex-direction: column;
      align-items: stretch;
      padding: 0.75rem;
      gap: 0;
      z-index: 999;
      justify-content: flex-start;
    }

    nav.mobile-open { display: flex; }

    nav > a {
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-size: 0.95rem;
    }

    .nav-dropdown { width: 100%; }

    .nav-dropdown-trigger {
      width: 100%;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-size: 0.95rem;
      justify-content: space-between;
    }

    .dropdown-panel {
      position: static;
      transform: none;
      box-shadow: none;
      border: none;
      border-radius: 0;
      padding: 0.25rem 0 0.25rem 1rem;
      min-width: unset;
      background: var(--gray-50, #F8FAFB);
      border-radius: 0.5rem;
      margin-top: 0.25rem;
    }
  }
</style>
