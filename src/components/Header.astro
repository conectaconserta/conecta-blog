---
const navLinks = [
  { href: '/', label: 'Início' },
  { href: '/blog', label: 'Blog' },
  { href: '/contato', label: 'Contato' },
];

const currentPath = Astro.url.pathname;
---

<header>
  <div class="container">
    <a href="/" class="logo">
      <img src="/images/logo-header.png" alt="Conecta Phone" class="logo-img" />
    </a>
    <nav>
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[{ active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <a
      href="https://wa.me/5581991862060?text=Olá%2C%20vim%20do%20blog%20Conecta%20e%20preciso%20de%20um%20or%C3%A7amento%20gr%C3%A1tis"
      class="btn-header-cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      WhatsApp
    </a>
  </div>
</header>

<style>
  header {
    background: #fff;
    padding: 1rem 0;
    border-bottom: 1px solid #E8EFF4;
    box-shadow: 0 1px 12px rgba(20,51,79,0.07);
  }

  header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 40px;
    width: auto;
    object-fit: contain;
  }

  nav {
    display: flex;
    gap: 0.5rem;
  }

  nav a {
    color: #14334F;
    padding: 0.45rem 0.9rem;
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
    text-decoration: none;
    position: relative;
  }

  nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0.9rem;
    right: 0.9rem;
    height: 2px;
    background: #1FC3FF;
    border-radius: 2px;
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  nav a:hover { color: #0099CC; text-decoration: none; }
  nav a:hover::after { transform: scaleX(1); }

  nav a.active {
    color: #0099CC;
    font-weight: 600;
    text-decoration: none;
  }

  nav a.active::after { transform: scaleX(1); }

  .btn-header-cta {
    background: #25D366;
    color: #fff;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .btn-header-cta:hover {
    background: #1fad54;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(37,211,102,0.38);
  }

  @media (max-width: 640px) {
    nav a { padding: 0.4rem 0.5rem; font-size: 0.85rem; }
    .btn-header-cta { display: none; }
  }
</style>
