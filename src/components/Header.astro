---
const navLinks = [
  { href: '/', label: 'Início' },
  { href: '/blog', label: 'Blog' },
  { href: '/contato', label: 'Contato' },
];

const currentPath = Astro.url.pathname;
---

<header>
  <div class="container">
    <a href="/" class="logo">
      <img src="/images/logo-header.png" alt="Conecta Phone" class="logo-img" />
    </a>
    <nav>
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[{ active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <a
      href="https://wa.me/5581991862060?text=Olá!%20Gostaria%20de%20um%20orçamento."
      class="btn-header-cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      WhatsApp
    </a>
  </div>
</header>

<style>
  header {
    background: #fff;
    padding: 0.85rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 3px solid var(--teal);
    box-shadow: 0 1px 8px rgba(0,0,0,0.08);
  }

  header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 40px;
    width: auto;
    object-fit: contain;
  }

  .logo-text {
    font-family: 'Poppins', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    color: #111827;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  nav {
    display: flex;
    gap: 0.25rem;
  }

  nav a {
    color: #374151;
    padding: 0.4rem 0.85rem;
    border-radius: 0.4rem;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s, background 0.2s;
    text-decoration: none;
  }

  nav a:hover,
  nav a.active {
    color: var(--teal-dark);
    background: rgba(0,188,212,0.07);
    text-decoration: none;
  }

  .btn-header-cta {
    background: #25D366;
    color: #fff;
    padding: 0.45rem 1rem;
    border-radius: 0.4rem;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    flex-shrink: 0;
    transition: background 0.2s;
  }

  .btn-header-cta:hover {
    background: #1fad54;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    nav a {
      padding: 0.4rem 0.5rem;
      font-size: 0.85rem;
    }

    .btn-header-cta {
      display: none;
    }
  }
</style>
