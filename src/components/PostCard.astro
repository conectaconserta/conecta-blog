---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  author: string;
  tags: string[];
}

const { title, description, slug, pubDate, author, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const firstTag = tags[0];
---

<article class="post-card">
  <div class="post-card-body">
    {firstTag && <span class="post-tag">{firstTag}</span>}
    <h2><a href={`/blog/${slug}`}>{title}</a></h2>
    <p>{description}</p>
    <footer>
      <span class="date">{formattedDate}</span>
      <a href={`/blog/${slug}`} class="read-more">Ler artigo →</a>
    </footer>
  </div>
</article>

<style>
  .post-card {
    background: #fff;
    border: 1px solid #D9E6EC;
    border-radius: 1rem;
    overflow: hidden;
    transition: box-shadow 0.3s cubic-bezier(0.16,1,0.3,1),
                transform 0.3s cubic-bezier(0.16,1,0.3,1),
                border-color 0.3s;
    display: flex;
    flex-direction: column;
    position: relative;
    cursor: pointer;
  }

  /* Cyan top accent bar */
  .post-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #1FC3FF 0%, #80e8ff 50%, #1FC3FF 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .post-card:hover {
    box-shadow: 0 12px 36px rgba(20,51,79,0.13), 0 2px 8px rgba(31,195,255,0.10);
    transform: translateY(-5px);
    border-color: rgba(31,195,255,0.30);
  }

  .post-card:hover::before { opacity: 1; }

  .post-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-tag {
    display: inline-block;
    background: rgba(31,195,255,0.12);
    color: #0099CC;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.8rem;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    border: 1px solid rgba(31,195,255,0.25);
    margin-bottom: 0.85rem;
    width: fit-content;
  }

  h2 {
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.45;
    margin-bottom: 0.65rem;
    letter-spacing: -0.01em;
    flex: 1;
  }

  h2 a {
    color: #14334F;
    text-decoration: none;
    transition: color 0.2s;
  }

  h2 a:hover { color: #0099CC; }

  p {
    color: #5F778B;
    font-size: 0.875rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid #EEF4F7;
  }

  .date { color: #BFCDD6; }

  .read-more {
    color: #0099CC;
    font-weight: 700;
    font-size: 0.82rem;
    text-decoration: none;
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    letter-spacing: 0.02em;
    transition: color 0.2s, gap 0.2s;
  }

  .read-more:hover {
    color: #1FC3FF;
    text-decoration: none;
  }
</style>
